# ══════════════════════════════════════════════════════════
# SISTEMA DE TIENDA EN LÍNEA — Laravel 12
# Desarrollado por Berny Otárola | github.com/BernyOtarola
# ══════════════════════════════════════════════════════════

# ── Laravel core ─────────────────────────────────────────
APP_NAME="Mi Tienda"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logs ─────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Base de datos ─────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nombre_tienda
DB_USERNAME=root
DB_PASSWORD=

# ── Sesiones ─────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Colas y caché ────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Correo (configurar con proveedor SMTP) ────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password_de_gmail
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=tu_correo@gmail.com
MAIL_FROM_NAME="${TIENDA_NOMBRE}"

# ══════════════════════════════════════════════════════════
# CONFIGURACIÓN DEL NEGOCIO — Editar estos valores
# ══════════════════════════════════════════════════════════

# ── Identidad ────────────────────────────────────────────
TIENDA_NOMBRE="Mi Tienda"
TIENDA_SLOGAN="Los mejores productos directo a tu puerta"
TIENDA_DESC="Descripción breve del negocio para SEO"
TIENDA_ADMIN_EMAIL=admin@ejemplo.com
TIENDA_EMOJI=🛒

# Ejemplos de emojis por rubro:
# Floristería:  🌸   Panadería: 🍞   Ropa: 👗   Mascotas: 🐾
# Cosméticos:  🧴   Restaurante: 🍕  Joyería: 💍  Ferretería: 🔧

# ── Colores (hex SIN el #) ────────────────────────────────
# Cambiá estos 5 valores para cambiar TODO el diseño del sitio

TIENDA_COLOR_PRIMARIO=2A4A1E
TIENDA_COLOR_PRIMARIO_CLARO=4A7A35
TIENDA_COLOR_ACENTO=C4714A
TIENDA_COLOR_ROSA=E8B4A0
TIENDA_COLOR_FONDO=F8F5EE
TIENDA_COLOR_DORADO=C9A86A

# Paletas de ejemplo:
#
# 🌸 Floristería Bribrí (logo: corona + colibrí):
#   PRIMARIO=3A4D38 | CLARO=5E7355 | ACENTO=9C4A5A | ROSA=C08497 | FONDO=F5F1E8 | DORADO=C9A86A
#
# 🌸 Floristería verde:
#   PRIMARIO=2A4A1E | CLARO=4A7A35 | ACENTO=C4714A | ROSA=E8B4A0 | FONDO=F8F5EE
#
# 🍞 Panadería café:
#   PRIMARIO=5C3D1E | CLARO=8B6245 | ACENTO=D4A853 | ROSA=F5E6D3 | FONDO=FDF8F0
#
# 👗 Boutique rosa:
#   PRIMARIO=8B2252 | CLARO=C4457A | ACENTO=F0A0C0 | ROSA=FAD4E5 | FONDO=FFF5F8
#
# 🐾 Mascotas azul:
#   PRIMARIO=1A3A5C | CLARO=2E6DA4 | ACENTO=F5A623 | ROSA=D4E8FA | FONDO=F0F7FF
#
# 🧴 Cosméticos morado:
#   PRIMARIO=4A1A6B | CLARO=7B35A8 | ACENTO=E8A0D4 | ROSA=F5D4EF | FONDO=FDF5FF

# ── Contacto ─────────────────────────────────────────────
TIENDA_WHATSAPP=50600000000
TIENDA_TELEFONO=
TIENDA_DIRECCION="Costa Rica"
TIENDA_HORARIO="Lunes a Sábado: 8:00am - 6:00pm"

# Google Maps (opcional)
TIENDA_MAPS_URL=
TIENDA_MAPS_EMBED=

# ── Envío ─────────────────────────────────────────────────
TIENDA_COSTO_ENVIO=3000
TIENDA_ENVIO_GRATIS_DESDE=0

# ── Moneda ────────────────────────────────────────────────
TIENDA_MONEDA_SIMBOLO=₡
TIENDA_MONEDA_DECIMALES=0
TIENDA_MONEDA_SEP_DEC=,
TIENDA_MONEDA_SEP_MIL=.
TIENDA_MONEDA_CODIGO=CRC

# ── Pedidos ───────────────────────────────────────────────
# Prefijo de 3 letras para números de pedido (ej: BRI-A1B2C3-2026)
TIENDA_PREFIJO_PEDIDO=TDA

# ── Productos ─────────────────────────────────────────────
TIENDA_DESTACADOS_HOME=6
TIENDA_IMAGEN_MAX_KB=5120

# ── Redes sociales (dejar vacío si no aplica) ─────────────
TIENDA_FACEBOOK=
TIENDA_INSTAGRAM=
TIENDA_TIKTOK=

# ── SEO ───────────────────────────────────────────────────
TIENDA_SEO_TITULO=
TIENDA_SEO_DESC=
TIENDA_SEO_KEYWORDS=

# ── AWS (no requerido) ────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
